# Public env vars must be prefixed with EXPO_PUBLIC_ to be available in the app.
# Copy this file to `.env` and adjust as needed.
#
# The backend serves routes under /api, so include it in the URL.
# Android emulator -> host machine: http://10.0.2.2:3000/api
# iOS simulator / web:               http://localhost:3000/api
# Physical device:                   http://<your-LAN-IP>:3000/api
# Production:                         https://smartsupply.gr/api
EXPO_PUBLIC_API_URL=http://localhost:3000/api
